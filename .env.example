# =============================================================================
# Newsletter Ad Marketplace — Environment Variables
# =============================================================================
# Copy this file to .env and fill in the values.
# NEVER commit .env to version control.
# =============================================================================

# --- Application ---
NODE_ENV=development
PORT=3001
LOG_LEVEL=debug
APP_URL=http://localhost:5173
API_URL=http://localhost:3001

# --- Database (PostgreSQL + pgvector) ---
DATABASE_URL=postgresql://adstack:adstack_dev@localhost:5433/adstack_dev

# --- Redis ---
REDIS_URL=redis://localhost:6379

# --- Session / Auth ---
SESSION_SECRET=change-me-to-a-random-64-char-string
COOKIE_DOMAIN=localhost

# --- Stripe ---
STRIPE_SECRET_KEY=sk_test_...
STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_CONNECT_CLIENT_ID=ca_...

# --- OpenAI (Embeddings) ---
OPENAI_API_KEY=sk-...

# --- Anthropic (Content Generation) ---
ANTHROPIC_API_KEY=sk-ant-...

# --- ESP: Beehiiv ---
# Publisher-specific — stored in DB, not here.
# These are platform-level defaults for testing.
BEEHIIV_API_KEY=

# --- ESP: ConvertKit/Kit ---
CONVERTKIT_API_SECRET=

# --- ESP: Mailchimp ---
MAILCHIMP_API_KEY=

# --- Email (Transactional) ---
# Provider TBD — Resend, Postmark, or SES
EMAIL_FROM=noreply@adstack.io
EMAIL_PROVIDER=resend
RESEND_API_KEY=re_...

# --- Encryption ---
# Used to encrypt sensitive fields at rest (ESP API keys, etc.)
ENCRYPTION_KEY=change-me-to-a-random-32-byte-hex-string

# --- Sentry (Error Tracking) ---
SENTRY_DSN=
